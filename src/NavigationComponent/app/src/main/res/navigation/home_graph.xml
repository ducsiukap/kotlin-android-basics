<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.vduczz.navigationcomponent.home.items.ListItemFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_list_item_to_detail_item"
            app:destination="@id/item_detail_fragment" />

    </fragment>

    <fragment
        android:id="@+id/item_detail_fragment"
        android:name="com.vduczz.navigationcomponent.home.items.ItemDetailFragment"
        android:label="Item"
        tools:layout="@layout/fragment_item_detail">
        <argument
            android:name="itemName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.vduczz.navigationcomponent.home.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

</navigation>